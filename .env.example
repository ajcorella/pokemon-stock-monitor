# Best Buy Developer API key (free: https://developer.bestbuy.com/)
BESTBUY_API_KEY=your_api_key_here

# Twilio SMS credentials (https://console.twilio.com/)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
NOTIFY_PHONE_NUMBER=+1234567890

# Your zip code for store proximity search
ZIP_CODE=85308

# How many miles from your zip to search (default 25)
SEARCH_RADIUS_MILES=25
